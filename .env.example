APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=scaffolding_landing_page
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Forgot-password OTP is sent via the default mailer. Set real SMTP credentials in production.
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Ziina payment gateway (game-sessions). See config/ziina.php
ZIINA_API_BASE=https://api-v2.ziina.com/api
ZIINA_API_KEY=
# Leave empty to use: {APP_URL}/api/payment/success?payment_intent_id={PAYMENT_INTENT_ID} (recommended - credits sessions on redirect)
ZIINA_SUCCESS_URL=
# Where to redirect user after we credit sessions (frontend success page)
ZIINA_PAYMENT_SUCCESS_REDIRECT_URL=https://yourapp.com/payments/success
ZIINA_CANCEL_URL=https://yourapp.com/payments/cancel
ZIINA_CURRENCY=AED
ZIINA_MODE=sandbox
# Optional: HMAC secret for webhook verification. Set when configuring webhook in Ziina Dashboard.
ZIINA_WEBHOOK_SECRET=

# Shop checkout (e-commerce)
SHOP_SHIPPING_FEE_AED=30
SHOP_FRONTEND_CONFIRMATION_URL=https://<frontend-domain>/order/confirmation
SHOP_FRONTEND_CANCEL_URL=
SHOP_CONFIRMATION_TOKEN_TTL_MINUTES=60
SHOP_SUPPORT_CONTACT=support@khararif.ae

# Frontend origins for API CORS
# Next.js frontend should set NEXT_PUBLIC_BASE_URL to its origin, e.g. https://shop.example.com
NEXT_PUBLIC_BASE_URL=http://localhost:3000
FRONTEND_BASE_URL=

# Firebase Realtime Database (for game sync). See kreait/laravel-firebase
FIREBASE_CREDENTIALS=
FIREBASE_DATABASE_URL=

# Cloudflare Turnstile (bot protection for contact-us endpoint)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
TURNSTILE_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
